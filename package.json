    "interface": "stitch/stitch"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.3.0",
    "node-fetch": "^3.3.2",
    "yaml": "^2.8.2"
  }
