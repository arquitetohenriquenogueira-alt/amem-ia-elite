{
  "cleanUrls": true,
  "buildCommand": "rm -rf dist && mkdir -p dist && cp -rv FRONTEND/* dist/",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/stitch/splash/code(.*)",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/stitch/am_m_ia_premium_splash_screen/(.*)",
      "destination": "/stitch/splash-premium-v1/$1",
      "permanent": true
    },
    {
      "source": "/stitch/am_m_ia_modo_sementinha_2/(.*)",
      "destination": "/stitch/kids-modo-2/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/styles/(.*)",
      "destination": "/public/styles/$1"
    },
    {
      "source": "/scripts/(.*)",
      "destination": "/public/scripts/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/public/assets/$1"
    },
    {
      "source": "/stitch/(.*)",
      "destination": "/stitch/$1"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "mode",
          "value": "app"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/stitch/splash-premium-v1/code.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
